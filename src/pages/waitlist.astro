---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Waitlist — Ennyn"
  description="Join the Ennyn waitlist."
  register="a"
  activeNav="waitlist"
>
  <main class="waitlist">

    <section class="hero">
      <div class="wrap-narrow">
        <p class="kicker">Waitlist</p>
        <h1>You're on the list.</h1>
        <p class="lede">
          Thanks for signing up. We're talking to a small group of design partners ahead
          of opening more broadly. If your firm fits, we'll be in touch.
        </p>
      </div>
    </section>

    <section class="next">
      <div class="wrap-narrow">
        <h2>What happens next.</h2>
        <ol>
          <li>We read every signup ourselves &mdash; no auto-replies.</li>
          <li>If you're a fit for the design-partner cohort, we'll reach out within the week.</li>
          <li>If you're not yet, you'll get one update when there's something real to show.</li>
        </ol>
      </div>
    </section>

    <section class="intake">
      <div class="wrap-narrow">
        <h2>Optional: tell us about your stack.</h2>
        <p>
          The fastest way to move you up the list is to tell us what your back office actually runs on today.
        </p>
        <form class="intake-form" onsubmit="return false;">
          <label>
            <span>Your role</span>
            <input type="text" name="role" placeholder="Owner / Operations manager / etc." />
          </label>
          <label>
            <span>Industry &amp; size (e.g. PM firm, 200 doors)</span>
            <input type="text" name="size" placeholder="Property management, 150 doors" />
          </label>
          <label>
            <span>The seam that hurts most</span>
            <textarea name="pain" rows="3" placeholder="When a new hire joins, what breaks?"></textarea>
          </label>
          <button type="submit" class="btn">Send (placeholder &mdash; not yet wired)</button>
          <p class="form-note">This form isn't connected yet. We'll wire it to a real intake when we exit stealth. For now: <a href="mailto:hello@ennyn.io">hello@ennyn.io</a>.</p>
        </form>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .waitlist section {
    padding: 80px 0;
    border-bottom: 1px solid var(--line);
  }
  .waitlist .hero {
    padding: 120px 0 56px;
  }
  .waitlist .kicker { margin-bottom: 18px; }
  .waitlist h1 { margin-bottom: 18px; }
  .waitlist h2 { margin-bottom: 22px; }

  .waitlist .next ol {
    list-style: none;
    counter-reset: step;
  }
  .waitlist .next li {
    counter-increment: step;
    padding: 14px 0;
    padding-left: 44px;
    position: relative;
    font-size: 17px;
    line-height: 1.55;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }
  .waitlist .next li:first-child { border-top: none; }
  .waitlist .next li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 14px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--rust);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .waitlist .intake-form {
    display: grid;
    gap: 18px;
    max-width: 560px;
    margin-top: 12px;
  }
  .waitlist .intake-form label {
    display: grid;
    gap: 6px;
  }
  .waitlist .intake-form label span {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .waitlist .intake-form input,
  .waitlist .intake-form textarea {
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.6);
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
  }
  .waitlist .intake-form input:focus,
  .waitlist .intake-form textarea:focus {
    outline: none;
    border-color: var(--rust);
    background: #fff;
  }
  .waitlist .intake-form .btn { width: fit-content; }
  .waitlist .form-note {
    font-size: 13px;
    color: var(--soft);
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .waitlist section { padding: 56px 0; }
    .waitlist .hero { padding-top: 80px; }
  }
</style>
