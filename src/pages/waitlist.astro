---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Waitlist — Ennyn"
  description="Join the Ennyn waitlist."
  register="a"
  activeNav="waitlist"
  darkHero={true}
>
  <main class="waitlist">

    <!-- DARK CINEMATIC HERO -->
    <section class="hero-dark">
      <div class="hero-content">
        <svg class="archway" viewBox="0 0 100 130" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M 18 130 L 18 50 A 32 32 0 0 1 82 50 L 82 130" stroke-width="1.2"/>
          <path d="M 28 130 L 28 56 A 22 22 0 0 1 72 56 L 72 130" stroke-width="0.6" opacity="0.45"/>
          <circle cx="50" cy="36" r="5" stroke-width="0.7"/>
          <circle cx="50" cy="36" r="1.4" fill="currentColor" stroke="none"/>
          <line x1="50" y1="26" x2="50" y2="32" stroke-width="0.5" opacity="0.6"/>
          <line x1="50" y1="40" x2="50" y2="46" stroke-width="0.5" opacity="0.6"/>
          <line x1="40" y1="36" x2="46" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="54" y1="36" x2="60" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="10" y1="130" x2="90" y2="130" stroke-width="1.4"/>
          <line x1="4" y1="133.5" x2="96" y2="133.5" stroke-width="0.5" opacity="0.4"/>
        </svg>
        <p class="kicker">Waitlist</p>
        <h1>You're on the list.</h1>
        <p class="lede">
          Thanks for joining. We're talking to a small group of design partners
          ahead of opening more broadly.
        </p>
        <p class="lede">
          If your firm fits, we'll be in touch.
        </p>
      </div>
      <span class="scroll-cue">↓ What's next</span>
    </section>

    <section class="next">
      <div class="wrap-narrow">
        <h2>What happens next.</h2>
        <ol>
          <li>We read every signup ourselves &mdash; no auto-replies.</li>
          <li>If you're a fit for the design-partner cohort, we'll reach out within the week.</li>
          <li>If you're not yet, you'll get one update when there's something real to show.</li>
        </ol>
      </div>
    </section>

    <section class="intake">
      <div class="wrap-narrow">
        <h2>Optional: tell us about your stack.</h2>
        <p>
          The fastest way to move you up the list is to tell us what your back office actually runs on today.
        </p>
        <form class="intake-form" action="https://formsubmit.co/founder@ennyn.io" method="POST">
          <label>
            <span>Your email (so we can reach you)</span>
            <input type="email" name="email" placeholder="you@company.com" required />
          </label>
          <label>
            <span>Your role</span>
            <input type="text" name="role" placeholder="Owner / Operations manager / etc." />
          </label>
          <label>
            <span>Industry &amp; size (e.g. PM firm, 200 doors)</span>
            <input type="text" name="industry_and_size" placeholder="Property management, 150 doors" />
          </label>
          <label>
            <span>The seam that hurts most</span>
            <textarea name="seam_that_hurts" rows="3" placeholder="When a new hire joins, what breaks?"></textarea>
          </label>
          <button type="submit" class="btn">Send</button>
          <p class="form-note">We read every submission ourselves. Or skip the form: <a href="mailto:founder@ennyn.io">founder@ennyn.io</a>.</p>
          <!-- FormSubmit config -->
          <input type="hidden" name="_subject" value="Ennyn intake — design partner candidate" />
          <input type="hidden" name="_next" value="https://ennyn-pf.github.io/waitlist?sent=1" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        </form>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .waitlist > main > section:not(.hero-dark) {
    padding: 80px 0;
    border-bottom: 1px solid var(--line);
  }
  .waitlist .next {
    background: var(--paper);
    position: relative;
    margin-top: -40px;
    z-index: 2;
    padding-top: 56px !important;
  }
  .waitlist h1 { margin-bottom: 18px; }
  .waitlist h2 { margin-bottom: 22px; }

  .waitlist .next ol {
    list-style: none;
    counter-reset: step;
  }
  .waitlist .next li {
    counter-increment: step;
    padding: 14px 0;
    padding-left: 44px;
    position: relative;
    font-size: 17px;
    line-height: 1.55;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }
  .waitlist .next li:first-child { border-top: none; }
  .waitlist .next li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 14px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--rust);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .waitlist .intake-form {
    display: grid;
    gap: 18px;
    max-width: 560px;
    margin-top: 12px;
  }
  .waitlist .intake-form label {
    display: grid;
    gap: 6px;
  }
  .waitlist .intake-form label span {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .waitlist .intake-form input,
  .waitlist .intake-form textarea {
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.6);
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
  }
  .waitlist .intake-form input:focus,
  .waitlist .intake-form textarea:focus {
    outline: none;
    border-color: var(--rust);
    background: #fff;
  }
  .waitlist .intake-form .btn { width: fit-content; }
  .waitlist .form-note {
    font-size: 13px;
    color: var(--soft);
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .waitlist > main > section:not(.hero-dark) { padding: 56px 0; }
    .waitlist .next { margin-top: -20px; padding-top: 40px !important; }
  }
</style>
