---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Ennyn — The AI back-office agent for SMBs"
  description="Orchestration across the systems your business already runs on. We don't replace your tools. We close the seams between them."
  register="a"
  activeNav="home"
  darkHero={true}
>
  <main class="home">

    <!-- DARK CINEMATIC HERO: cross the threshold first. Don't name Ennyn yet. -->
    <section class="hero-dark">
      <div class="hero-content">
        <svg class="archway" viewBox="0 0 100 130" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M 18 130 L 18 50 A 32 32 0 0 1 82 50 L 82 130" stroke-width="1.2"/>
          <path d="M 28 130 L 28 56 A 22 22 0 0 1 72 56 L 72 130" stroke-width="0.6" opacity="0.45"/>
          <circle cx="50" cy="36" r="5" stroke-width="0.7"/>
          <circle cx="50" cy="36" r="1.4" fill="currentColor" stroke="none"/>
          <line x1="50" y1="26" x2="50" y2="32" stroke-width="0.5" opacity="0.6"/>
          <line x1="50" y1="40" x2="50" y2="46" stroke-width="0.5" opacity="0.6"/>
          <line x1="40" y1="36" x2="46" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="54" y1="36" x2="60" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="10" y1="130" x2="90" y2="130" stroke-width="1.4"/>
          <line x1="4" y1="133.5" x2="96" y2="133.5" stroke-width="0.5" opacity="0.4"/>
        </svg>
        <p class="kicker">Stealth · Coming soon</p>
        <h1>Your back office and your operations run on software that doesn't talk.</h1>
        <p class="lede">
          Every SMB lives on two parallel software worlds. One pays the people.
          The other runs the work. Nothing connects them.
        </p>
        <p class="lede">
          The seams between them are where the company actually runs &mdash; and
          no incumbent is incentivized to build the bridge.
        </p>
      </div>
      <span class="scroll-cue">↓ Scroll</span>
    </section>

    <!-- THE TWO STACKS — visual proof, warm canvas -->
    <section class="stacks">
      <div class="wrap-mid">
        <div class="stacks-grid">
          <div class="stack">
            <p class="stack-label">The ops stack</p>
            <p class="stack-tools">AppFolio · Buildium · Jobber · ServiceTitan · Mindbody · the industry tool that runs your unit of work</p>
          </div>
          <div class="gap-mark">⚡</div>
          <div class="stack">
            <p class="stack-label">The people stack</p>
            <p class="stack-tools">Gusto · QuickBooks · Workspace · LinkedIn · Instagram · Google Ads · Mailchimp · the tools that run you as an employer, a business, a brand, and a pipeline</p>
          </div>
        </div>
        <p class="gap-caption">No vendor owns the seam between them.</p>
      </div>
    </section>

    <!-- REVEAL: name Ennyn -->
    <section class="reveal">
      <div class="wrap-narrow">
        <p class="kicker">Ennyn</p>
        <h2>The AI back-office agent for SMBs.</h2>
        <p class="lede">
          Orchestration across the systems your business already runs on.
          We don't replace your tools. We close the seams between them.
        </p>
      </div>
    </section>

    <!-- VALUE PROPS: three differentiators -->
    <section class="props">
      <div class="wrap">
        <div class="props-grid">
          <article class="prop">
            <p class="prop-num">01</p>
            <h3>Between the boxes</h3>
            <p>All-in-one HR platforms closed the seams <em>within</em> back office. Ennyn closes the seams <em>between</em> back office and operations &mdash; the orchestration no single vendor owns.</p>
          </article>
          <article class="prop">
            <p class="prop-num">02</p>
            <h3>Orchestration, not replacement</h3>
            <p>We plug into the systems-of-record you already pay for &mdash; AppFolio Stack, Buildium Marketplace, Gusto, QuickBooks. No rip and replace.</p>
          </article>
          <article class="prop">
            <p class="prop-num">03</p>
            <h3>A service, not a tool</h3>
            <p>Days, not quarters. No software to learn, no integration project to scope, no in-house ops team to hire. The team and the agents are one delivery system.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- WAITLIST CTA -->
    <section class="cta">
      <div class="wrap-narrow">
        <h2>Get on the waitlist.</h2>
        <p class="lede">
          We're talking to a small group of design partners. If your back office runs on the seams between four vendors, we'd like to hear from you.
        </p>
        <form class="waitlist-form" action={`${base}/waitlist`} method="get">
          <input type="email" name="email" placeholder="you@company.com" required class="waitlist-input" />
          <button type="submit" class="btn">Join waitlist</button>
        </form>
        <p class="cta-fine">No spam. We'll be in touch when there's something real to show.</p>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* Sections after the dark hero — warm canvas */
  .home > main > section:not(.hero-dark) {
    padding: 112px 0;
    border-bottom: 1px solid var(--line);
  }
  .home h2 { margin-bottom: 20px; }
  .home p.lede + p.lede { margin-top: 16px; }

  /* Stacks visual — sits right under the threshold */
  .home .stacks {
    background: var(--paper-2);
    padding-top: 84px !important;
    padding-bottom: 84px !important;
    position: relative;
    margin-top: -40px;
    z-index: 2;
  }
  .home .stacks-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
    margin-bottom: 28px;
  }
  .home .stack {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.5);
    padding: 26px 24px;
    border-radius: 4px;
  }
  .home .stack-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--slate);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .home .stack-tools {
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted);
    max-width: none;
  }
  .home .gap-mark {
    font-size: 44px;
    color: var(--rust);
    line-height: 1;
    text-align: center;
    filter: drop-shadow(0 0 8px rgba(180, 71, 31, 0.25));
  }
  .home .gap-caption {
    text-align: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    font-weight: 600;
    max-width: none;
    margin-top: 12px;
  }

  /* Reveal section — the brand name moment. Hierarchy: NAME big, tagline supporting. */
  .home .reveal {
    text-align: center;
    padding-top: 128px !important;
    padding-bottom: 128px !important;
  }
  .home .reveal .kicker {
    font-family: 'Fraunces', serif;
    font-size: clamp(56px, 7.5vw, 96px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: none;
    color: var(--ink);
    line-height: 0.95;
    margin-bottom: 18px;
  }
  .home .reveal h2 {
    font-family: 'Fraunces', serif;
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 600;
    font-style: italic;
    color: var(--muted);
    letter-spacing: -0.005em;
    margin: 0 auto 32px;
    max-width: 32ch;
  }
  .home .reveal .lede {
    margin: 0 auto;
    text-align: center;
  }

  /* Props */
  .home .props-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .home .prop {
    padding: 32px 28px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--line);
    border-radius: 4px;
    position: relative;
  }
  .home .prop-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--rust);
    font-weight: 600;
    margin-bottom: 14px;
    max-width: none;
  }
  .home .prop h3 {
    margin-bottom: 12px;
  }
  .home .prop p {
    font-size: 15px;
    line-height: 1.6;
  }
  .home .prop em {
    font-style: italic;
    color: var(--rust);
    font-weight: 700;
  }

  /* CTA */
  .home .cta { text-align: center; }
  .home .cta h2 { margin-bottom: 16px; }
  .home .cta .lede { margin: 0 auto; }
  .home .waitlist-form {
    display: flex;
    gap: 12px;
    margin: 28px auto 0;
    max-width: 480px;
  }
  .home .waitlist-input {
    flex: 1;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.7);
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
  }
  .home .waitlist-input:focus {
    outline: none;
    border-color: var(--rust);
    background: #fff;
  }
  .home .cta-fine {
    margin: 18px auto 0;
    font-size: 13px;
    color: var(--soft);
  }

  @media (max-width: 768px) {
    .home > main > section:not(.hero-dark) { padding: 64px 0; }
    .home .stacks-grid { grid-template-columns: 1fr; }
    .home .gap-mark { padding: 8px 0; }
    .home .props-grid { grid-template-columns: 1fr; }
    .home .waitlist-form { flex-direction: column; }
  }
</style>
