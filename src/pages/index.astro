---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Ennyn — The AI back-office agent for SMBs"
  description="Orchestration across the systems your business already runs on. We don't replace your tools. We close the seams between them."
  register="a"
  activeNav="home"
  darkHero={true}
>
  <main class="home">

    <!-- DARK CINEMATIC HERO: cross the threshold first. Don't name Ennyn yet. -->
    <section class="hero-dark">
      <div class="hero-content">
        <svg class="archway" viewBox="0 0 100 130" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M 18 130 L 18 50 A 32 32 0 0 1 82 50 L 82 130" stroke-width="1.2"/>
          <path d="M 28 130 L 28 56 A 22 22 0 0 1 72 56 L 72 130" stroke-width="0.6" opacity="0.45"/>
          <circle cx="50" cy="36" r="5" stroke-width="0.7"/>
          <circle cx="50" cy="36" r="1.4" fill="currentColor" stroke="none"/>
          <line x1="50" y1="26" x2="50" y2="32" stroke-width="0.5" opacity="0.6"/>
          <line x1="50" y1="40" x2="50" y2="46" stroke-width="0.5" opacity="0.6"/>
          <line x1="40" y1="36" x2="46" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="54" y1="36" x2="60" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="10" y1="130" x2="90" y2="130" stroke-width="1.4"/>
          <line x1="4" y1="133.5" x2="96" y2="133.5" stroke-width="0.5" opacity="0.4"/>
        </svg>
        <p class="kicker">Stealth · Coming soon</p>
        <h1>Your back office and your operations run on software that doesn't talk.</h1>
        <p class="lede">
          Every SMB lives on two parallel software worlds. One pays the people.
          The other runs the work. Nothing connects them.
        </p>
        <p class="lede">
          The seams between them are where the company actually runs &mdash; and
          no incumbent is incentivized to build the bridge.
        </p>
      </div>
      <span class="scroll-cue">↓ Scroll</span>
    </section>

    <!-- THE TWO STACKS — visual proof, warm canvas -->
    <section class="stacks">
      <div class="wrap-mid">
        <div class="stacks-grid">
          <div class="stack">
            <p class="stack-label">The ops stack</p>
            <p class="stack-tools">AppFolio · ServiceTitan · Mindbody · Toast · the industry tool that runs your unit of work</p>
          </div>
          <div class="gap-mark">⚡</div>
          <div class="stack">
            <p class="stack-label">The people stack</p>
            <p class="stack-tools">Gusto · QuickBooks · Workspace · Instagram · Google Ads · the tools that run you as an employer, a business, a brand, and a pipeline</p>
          </div>
        </div>
        <p class="gap-caption">No vendor owns the seam between them.</p>
      </div>
    </section>

    <!-- REVEAL: name Ennyn -->
    <section class="reveal">
      <div class="wrap-narrow">
        <svg class="reveal-arch" viewBox="0 0 100 130" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M 18 130 L 18 50 A 32 32 0 0 1 82 50 L 82 130" stroke-width="1.2"/>
          <path d="M 28 130 L 28 56 A 22 22 0 0 1 72 56 L 72 130" stroke-width="0.6" opacity="0.45"/>
          <circle cx="50" cy="36" r="5" stroke-width="0.7"/>
          <circle cx="50" cy="36" r="1.4" fill="currentColor" stroke="none"/>
          <line x1="50" y1="26" x2="50" y2="32" stroke-width="0.5" opacity="0.6"/>
          <line x1="50" y1="40" x2="50" y2="46" stroke-width="0.5" opacity="0.6"/>
          <line x1="40" y1="36" x2="46" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="54" y1="36" x2="60" y2="36" stroke-width="0.5" opacity="0.6"/>
          <line x1="10" y1="130" x2="90" y2="130" stroke-width="1.4"/>
          <line x1="4" y1="133.5" x2="96" y2="133.5" stroke-width="0.5" opacity="0.4"/>
        </svg>
        <p class="kicker">Ennyn</p>
        <h2>The AI back-office agent for SMBs.</h2>
        <p class="lede">
          Orchestration across the systems your business already runs on.
          We don't replace your tools. We close the seams between them.
        </p>
      </div>
    </section>

    <!-- VALUE PROPS: three differentiators -->
    <section class="props">
      <div class="wrap">
        <div class="props-grid">
          <article class="prop">
            <p class="prop-num">01</p>
            <h3>Between the boxes</h3>
            <p>All-in-one HR platforms closed the seams <em>within</em> back office. Ennyn closes the seams <em>between</em> back office and operations &mdash; the orchestration no single vendor owns.</p>
          </article>
          <article class="prop">
            <p class="prop-num">02</p>
            <h3>Orchestration, not replacement</h3>
            <p>We plug into the systems-of-record you already pay for &mdash; AppFolio Stack, Buildium Marketplace, Gusto, QuickBooks. No rip and replace.</p>
          </article>
          <article class="prop">
            <p class="prop-num">03</p>
            <h3>A service, not a tool</h3>
            <p>Days, not quarters. No software to learn, no integration project to scope, no in-house ops team to hire. The team and the agents are one delivery system.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- INDUSTRIES HANDOFF — five vertical entrypoints -->
    <section class="industries-link">
      <div class="wrap">
        <div class="industries-link-head">
          <p class="kicker">Industries</p>
          <h2>Five surfaces. One thesis.</h2>
          <p class="lede">Same orchestration shape, different tools and language. Pick yours.</p>
        </div>

        <div class="industries-link-grid">
          <a href={`${base}/property-management`} class="ind-card accent-rust">
            <h3>Property management</h3>
            <p class="ind-tools">AppFolio · Buildium</p>
            <span class="ind-arrow">→</span>
          </a>
          <a href={`${base}/fitness`} class="ind-card accent-gold">
            <h3>Fitness studios &amp; gyms</h3>
            <p class="ind-tools">Mindbody · Glofox</p>
            <span class="ind-arrow">→</span>
          </a>
          <a href={`${base}/trades`} class="ind-card accent-slate">
            <h3>Home services &amp; trades</h3>
            <p class="ind-tools">ServiceTitan · Jobber</p>
            <span class="ind-arrow">→</span>
          </a>
          <a href={`${base}/medical`} class="ind-card accent-moss">
            <h3>Dental &amp; small medical</h3>
            <p class="ind-tools">Dentrix · ZocDoc</p>
            <span class="ind-arrow">→</span>
          </a>
          <a href={`${base}/restaurants`} class="ind-card accent-plum">
            <h3>Restaurant &amp; café groups</h3>
            <p class="ind-tools">Toast · Square</p>
            <span class="ind-arrow">→</span>
          </a>
        </div>

        <p class="industries-link-foot">
          <a href={`${base}/industries`}>See all five →</a>
        </p>
      </div>
    </section>

    <!-- WAITLIST CTA -->
    <section class="cta">
      <div class="wrap-narrow">
        <h2>Get on the waitlist.</h2>
        <p class="lede">
          We're talking to a small group of design partners. If your back office runs on the seams between four vendors, we'd like to hear from you.
        </p>
        <form class="waitlist-form" action={`${base}/waitlist`} method="get">
          <input type="email" name="email" placeholder="you@company.com" required class="waitlist-input" />
          <button type="submit" class="btn">Join waitlist</button>
        </form>
        <p class="cta-fine">No spam. We'll be in touch when there's something real to show.</p>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* Sections after the dark hero — warm canvas */
  .home > main > section:not(.hero-dark) {
    padding: 112px 0;
    border-bottom: 1px solid var(--line);
  }
  .home h2 { margin-bottom: 20px; }
  .home p.lede + p.lede { margin-top: 16px; }

  /* Stacks visual — sits right under the threshold */
  .home .stacks {
    background: var(--paper-2);
    padding-top: 84px !important;
    padding-bottom: 84px !important;
    position: relative;
    margin-top: -40px;
    z-index: 2;
  }
  .home .stacks-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
    margin-bottom: 28px;
  }
  .home .stack {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.5);
    padding: 26px 24px;
    border-radius: 4px;
  }
  .home .stack-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--slate);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .home .stack-tools {
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted);
    max-width: none;
  }
  .home .gap-mark {
    font-size: 44px;
    color: var(--rust);
    line-height: 1;
    text-align: center;
    filter: drop-shadow(0 0 8px rgba(180, 71, 31, 0.25));
  }
  .home .gap-caption {
    text-align: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    font-weight: 600;
    max-width: none;
    margin-top: 12px;
  }

  /* Reveal section — the brand name moment. Hierarchy: NAME big, tagline supporting. */
  .home .reveal {
    text-align: center;
    padding-top: 128px !important;
    padding-bottom: 160px !important;
  }
  .home .reveal .reveal-arch {
    display: block;
    width: 130px;
    height: 169px;
    color: var(--ink);
    margin: 0 auto 36px;
  }
  .home .reveal .kicker {
    font-family: 'Cinzel', serif;
    font-size: clamp(44px, 6vw, 80px);
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 0.95;
    margin-bottom: 18px;
  }
  .home .reveal h2 {
    font-family: 'Fraunces', serif;
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 600;
    font-style: italic;
    color: var(--muted);
    letter-spacing: -0.005em;
    margin: 0 auto 32px;
    max-width: 32ch;
  }
  .home .reveal .lede {
    margin: 0 auto;
    text-align: center;
  }

  /* Props */
  .home .props-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .home .prop {
    padding: 32px 28px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--line);
    border-radius: 4px;
    position: relative;
  }
  .home .prop-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--rust);
    font-weight: 600;
    margin-bottom: 14px;
    max-width: none;
  }
  .home .prop h3 {
    margin-bottom: 12px;
  }
  .home .prop p {
    font-size: 15px;
    line-height: 1.6;
  }
  .home .prop em {
    font-style: italic;
    color: var(--rust);
    font-weight: 700;
  }

  /* CTA */
  .home .cta {
    text-align: center;
    padding-top: 144px !important;
    padding-bottom: 144px !important;
  }
  .home .cta h2 { margin-bottom: 20px; }
  .home .cta .lede { margin: 0 auto; }
  .home .waitlist-form {
    display: flex;
    gap: 12px;
    margin: 36px auto 0;
    max-width: 480px;
  }
  .home .waitlist-input {
    flex: 1;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.7);
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
  }
  .home .waitlist-input:focus {
    outline: none;
    border-color: var(--rust);
    background: #fff;
  }
  .home .cta-fine {
    margin: 32px auto 0;
    font-size: 13px;
    color: var(--soft);
  }

  /* === INDUSTRIES HANDOFF === */
  .home .industries-link {
    background: var(--paper-2);
    padding: 112px 0;
  }
  .home .industries-link-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 56px;
  }
  .home .industries-link-head .kicker {
    display: inline-block;
    margin-bottom: 16px;
  }
  .home .industries-link-head h2 {
    margin-bottom: 14px;
  }
  .home .industries-link-head .lede {
    margin: 0 auto;
    font-size: 17px;
    color: var(--muted);
  }
  .home .industries-link-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .home .ind-card {
    display: block;
    padding: 24px 20px 28px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-top-width: 3px;
    text-decoration: none;
    color: var(--ink);
    position: relative;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .home .ind-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(40, 32, 18, 0.08);
  }
  .home .ind-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .home .ind-card .ind-tools {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--soft);
    letter-spacing: 0.04em;
    line-height: 1.4;
    margin: 0 0 18px;
    max-width: none;
  }
  .home .ind-card .ind-arrow {
    font-family: 'Fraunces', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
  }
  .home .ind-card.accent-rust  { border-top-color: var(--rust); }
  .home .ind-card.accent-gold  { border-top-color: var(--gold); }
  .home .ind-card.accent-slate { border-top-color: var(--slate); }
  .home .ind-card.accent-moss  { border-top-color: var(--moss); }
  .home .ind-card.accent-plum  { border-top-color: var(--plum); }
  .home .ind-card.accent-rust:hover  { border-color: var(--rust); }
  .home .ind-card.accent-gold:hover  { border-color: var(--gold); }
  .home .ind-card.accent-slate:hover { border-color: var(--slate); }
  .home .ind-card.accent-moss:hover  { border-color: var(--moss); }
  .home .ind-card.accent-plum:hover  { border-color: var(--plum); }
  .home .industries-link-foot {
    text-align: center;
    margin: 36px auto 0;
    max-width: none;
    font-family: 'Inter', sans-serif;
  }
  .home .industries-link-foot a {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
  }
  .home .industries-link-foot a:hover {
    color: var(--rust);
    border-color: var(--rust);
  }

  @media (max-width: 1024px) {
    .home .industries-link-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .home > main > section:not(.hero-dark) { padding: 64px 0; }
    .home .stacks-grid { grid-template-columns: 1fr; }
    .home .gap-mark { padding: 8px 0; }
    .home .props-grid { grid-template-columns: 1fr; }
    .home .waitlist-form { flex-direction: column; }
    .home .industries-link { padding: 80px 0; }
    .home .industries-link-grid { grid-template-columns: repeat(2, 1fr); }
    .home .industries-link-head { margin-bottom: 36px; }
  }
</style>
