---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  register?: 'a' | 'b';
  activeNav?: 'home' | 'thesis' | 'industries' | 'about' | 'waitlist' | null;
  darkHero?: boolean;
}

const {
  title = 'Ennyn — The AI back-office agent for SMBs',
  description = 'Orchestration across the systems your business already runs on. We don\'t replace your tools. We close the seams between them.',
  register = 'a',
  activeNav = null,
  darkHero = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { href: `${base}/thesis`, label: 'Thesis', key: 'thesis' },
  { href: `${base}/industries`, label: 'Industries', key: 'industries' },
  { href: `${base}/about`, label: 'About', key: 'about' },
  { href: `${base}/waitlist`, label: 'Waitlist', key: 'waitlist' },
];

const bodyClass = [
  register === 'b' ? 'grain' : '',
  darkHero ? 'dark-hero-page' : '',
].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="en" class={`reg-${register}`}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body class={bodyClass}>

  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href={`${base}/`} class="nav-brand" aria-label="Ennyn home">
        <svg class="archway-mark" viewBox="0 0 100 130" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M 18 130 L 18 50 A 32 32 0 0 1 82 50 L 82 130" stroke-width="3"/>
          <line x1="10" y1="130" x2="90" y2="130" stroke-width="3"/>
          <circle cx="50" cy="36" r="5" stroke="none" fill="currentColor"/>
        </svg>
        <span>Ennyn</span>
      </a>
      <div class="nav-links">
        {links.map(link => (
          <a href={link.href} class={activeNav === link.key ? 'active' : ''}>{link.label}</a>
        ))}
      </div>
    </div>
  </nav>

  <slot />

  <footer class="footer">
    <div class="footer-inner">
      <div>Ennyn · ennyn.io · stealth</div>
      <div>© 2026 Ennyn</div>
    </div>
  </footer>

  {darkHero && (
    <script is:inline>
      (function () {
        const nav = document.getElementById('nav');
        if (!nav) return;
        const onScroll = function () {
          if (window.scrollY > window.innerHeight * 0.6) {
            nav.classList.add('scrolled');
          } else {
            nav.classList.remove('scrolled');
          }
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  )}

</body>
</html>

<style>
  .nav-links a.active { color: var(--ink); font-weight: 600; }
</style>
